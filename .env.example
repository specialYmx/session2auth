PORT=3000
BASE_PATH=/session-converter

# Public OAuth app settings used by the browser to build the login link.
# Defaults match the simplified local OpenAI OAuth flow used in team-helper.
OPENAI_CLIENT_ID=app_EMoamEEZ73f0CkXaXp7hrann
OPENAI_REDIRECT_URI=http://localhost:1455/auth/callback

# Optional: if your OAuth app is configured as a confidential client,
# place the client secret here. For PKCE public clients this can stay empty.
OPENAI_CLIENT_SECRET=

# Override only if your provider configuration differs.
OPENAI_AUTHORIZATION_URL=https://auth.openai.com/oauth/authorize
OPENAI_TOKEN_URL=https://auth.openai.com/oauth/token
OPENAI_SCOPE=openid profile email offline_access
